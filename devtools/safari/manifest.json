{
  "manifest_version": 3,
  "name": "Swiflow DevTools",
  "version": "0.1.12",
  "description": "Inspect Swiflow (Swift WASM) component trees and @State live in Safari's Web Inspector.",
  "devtools_page": "devtools.html",
  "host_permissions": ["<all_urls>"],
  "background": { "scripts": ["bridge-sw.js"], "persistent": false },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["bridge-content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["bridge-page.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
